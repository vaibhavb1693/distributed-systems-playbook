{
  "uid": "dead-letter-queue",
  "title": "Dead Letter Queue — KYC Pipeline",
  "description": "kyc-service (pipeline + retry + DLQ producer) and kyc-dlq-processor (DLQ consumer + replay + manual review).",
  "tags": ["distributed-systems-playbook", "dead-letter-queue"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Pipeline Outcomes (kyc-service)",
      "description": "success vs transient_failure (retried then DLQ'd) vs permanent_failure (DLQ'd immediately).",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "lineWidth": 2 } },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(kyc_pipeline_processed_total[$__rate_interval])) by (outcome)",
          "legendFormat": "{{outcome}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "DLQ Messages Received by Failure Type",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "lineWidth": 2 } },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(kyc_dlq_messages_received_total[$__rate_interval])) by (failure_type)",
          "legendFormat": "{{failure_type}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Manual Review Pending (alert fires above 10)",
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        { "refId": "A", "expr": "kyc_dlq_manual_review_pending" }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Replay Success Rate",
      "description": "replay_success / replay_attempted, across both auto-replay (poller) and manual Replay API calls.",
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 8 },
      "fieldConfig": {
        "defaults": { "unit": "percentunit" },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(kyc_dlq_replay_success_total) / sum(kyc_dlq_replay_attempted_total)"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Replay Attempts (attempted / success / failed)",
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 8 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "lineWidth": 2 } },
        "overrides": []
      },
      "targets": [
        { "refId": "A", "expr": "sum(rate(kyc_dlq_replay_attempted_total[$__rate_interval]))", "legendFormat": "attempted" },
        { "refId": "B", "expr": "sum(rate(kyc_dlq_replay_success_total[$__rate_interval]))", "legendFormat": "success" },
        { "refId": "C", "expr": "sum(rate(kyc_dlq_replay_failed_total[$__rate_interval]))", "legendFormat": "failed" }
      ]
    }
  ]
}
